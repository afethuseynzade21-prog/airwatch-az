# ── Secrets — NEVER commit these ─────────────────────────────────────────────
.streamlit/secrets.toml
.env

# ── Data ─────────────────────────────────────────────────────────────────────
data/raw/*.csv
data/db/*.duckdb       # DuckDB is a binary DB file — too large for git

# ── Model artifacts (large binaries) ─────────────────────────────────────────
outputs/best_model.pkl
outputs/*.pkl

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/
venv/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
