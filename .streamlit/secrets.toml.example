# AirWatch AZ — Streamlit Cloud Secrets
# =========================================
# Bu faylı Streamlit Cloud-a belə əlavə et:
#   App Settings → Secrets → aşağıdakı məzmunu yapışdır
#
# LOKAL İSTİFADƏ ÜÇÜN:
#   Bu faylı .streamlit/secrets.toml kimi saxla
#   .gitignore-a əlavə et (tokeni GitHub-a yükləmə!)

WAQI_TOKEN = "BURAYA_TOKENINI_YAZ"

# Necə alınır:
#   1. https://aqicn.org/data-platform/token/ → pulsuz qeydiyyat
#   2. E-mail gəlir → linkə basırsın → token aktivləşir
#   3. Test: https://api.waqi.info/feed/baku/?token=SENİN_TOKEN
#   4. {"status":"ok"} görürsənsə — işləyir
